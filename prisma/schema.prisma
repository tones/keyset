// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Song {
  id                 Int       @id @default(autoincrement())
  title              String
  imageUrl           String?
  youtubeUrl         String?
  analysis           String?
  analysisUpdatedAt  DateTime?
  compactView        Boolean   @default(false)
  songKey            String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  
  // One-to-many relationship with KeySets (ordered)
  keySets            KeySet[]
}

model KeySet {
  id          Int      @id @default(autoincrement())
  position    Int      // Position in the ordered list
  type        String   @default("chord") // "chord" or "flourish"
  scaleDegree Int?     // 1-7 Roman numeral scale degree (only used in key mode)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relationships
  song        Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  songId      Int
  keyPresses  KeyPress[]
  
  // Ensure each song has unique positions for key sets
  @@unique([songId, position])
}

model KeyPress {
  id          Int      @id @default(autoincrement())
  midiNote    Int      // MIDI note number (0-127)
  color       String   @default("red") // Key highlight color
  createdAt   DateTime @default(now())
  
  // Relationship
  keySet      KeySet   @relation(fields: [keySetId], references: [id], onDelete: Cascade)
  keySetId    Int
}
